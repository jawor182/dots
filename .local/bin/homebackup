#!/bin/bash

dirs=("$HOME/dox/" "$HOME/repos/" "$HOME/keepassxc/")
targetDir="/mnt/backup/"
currentDate=$(date "+%F")
backupFile="backup-$currentDate.tar.gz"
outputPath="$targetDir/$backupFile"

[ ! -d $targetDir ] && echo "Could not find target directory" && exit 1

echo "🔄 Starting backup: ${outputPath}"

if tar -czvf "$outputPath" "${dirs[@]}"; then
    echo "✅ Backup completed successfully!"
    echo "📦 Saved to: $outputPath"
else
    echo "❌ Backup failed!"
    exit 1
fi
